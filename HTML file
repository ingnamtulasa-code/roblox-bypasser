<!DOCTYPE html>
<html>
<head>
  <title>Take a Photo and Send to Discord</title>
</head>
<body>
  <h1>Click the button to take a photo and send it to Discord</h1>
  <button id="capture">Take Photo</button>

  <script>
    const button = document.getElementById('capture');

    button.addEventListener('click', async () => {
      // Request camera access
      const stream = await navigator.mediaDevices.getUserMedia({ video: true });
      const video = document.createElement('video');
      video.srcObject = stream;
      await video.play();

      // Capture photo
      const canvas = document.createElement('canvas');
      canvas.width = video.videoWidth;
      canvas.height = video.videoHeight;
      const context = canvas.getContext('2d');
      context.drawImage(video, 0, 0, canvas.width, canvas.height);

      const imageData = canvas.toDataURL('image/png');

      // Send to Discord via webhook
      const webhookUrl = 'https://discord.com/api/webhooks/1517202630999412736/PZ-71PbnykjvYs5WvLw-Z1hKf770snWSndb_-P4lDn5knKPaQxpFlOK879Tk_DR1E7rL';

      const response = await fetch(webhookUrl, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          content: '📸 Someone took a photo!',
          files: [imageData]
        })
      });

      console.log('Photo sent to Discord:', response);
    });
  </script>
</body>
</html>
